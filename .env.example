APP_NAME=Research Intelligence Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
AUTO_CREATE_TABLES=true

POSTGRES_DB=research_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/research_platform

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_API_KEY=
OPENALEX_MAILTO=your_email@example.com
OPENALEX_DEFAULT_PER_PAGE=25
